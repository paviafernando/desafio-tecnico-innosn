# Servidor
PORT=4000

# Base de datos
DATABASE_URL=postgres://tramites:tramites@localhost:5433/tramites

# Autenticación
JWT_SECRET=cambiar-en-produccion
JWT_EXPIRES_IN=8h

# Storage de archivos (S3 / MinIO) — mismo cliente para ambos, solo cambia la configuración
# Desarrollo local con MinIO:
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_BUCKET=tramites-archivos
STORAGE_FORCE_PATH_STYLE=true

# Producción con S3 real: dejar STORAGE_ENDPOINT vacío, STORAGE_FORCE_PATH_STYLE=false,
# y completar STORAGE_REGION/STORAGE_ACCESS_KEY_ID/STORAGE_SECRET_ACCESS_KEY/STORAGE_BUCKET
# con las credenciales del bucket real. No requiere rebuild, solo reiniciar el proceso.
